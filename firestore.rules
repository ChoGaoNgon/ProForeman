rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getEmployee() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'dang.nh.aprotrain@gmail.com' ||
        getEmployee().system_role == 'ADMIN'
      );
    }

    function isCEO() {
      return isSignedIn() && getEmployee().system_role == 'CEO';
    }

    function canManageProject(projectId) {
      let assignmentPath = /databases/$(database)/documents/project_assignments/$(request.auth.uid + "_" + projectId);
      let assignment = get(assignmentPath);
      let roleId = assignment.data.get('project_role_id', '');
      let roleData = get(/databases/$(database)/documents/project_roles/$(roleId)).data;
      let name = roleData.get('name', '').lower();
      let code = roleData.get('code', '').lower();
      
      return name.matches('.*(chỉ huy trưởng|bch|kế toán).*') || 
             code.matches('.*(cht|kt).*');
    }

    function isManagement(projectId) {
      return isAdmin() || isCEO() || (
        isSignedIn() && 
        projectId != null && 
        exists(/databases/$(database)/documents/project_assignments/$(request.auth.uid + "_" + projectId)) && 
        canManageProject(projectId)
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // Departments
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Employees
    match /employees/{empId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == empId; // Allow self-creation during login
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == empId && incoming().diff(existing()).affectedKeys().hasOnly(['photo_url', 'name']));
      allow delete: if isAdmin();
    }

    // Projects
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.contract_value is number;
      }
      
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isCEO()) && isValidProject(incoming());
      allow update: if isManagement(projectId) && isValidProject(incoming());
      allow delete: if isAdmin();
    }

    // Project Roles
    match /project_roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Project Assignments
    match /project_assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isCEO();
    }

    // Payments
    match /payments/{paymentId} {
      function isValidPayment(data) {
        return data.project_id is string && data.sequence is number && data.completed_value is number;
      }
      allow read: if isSignedIn();
      allow create: if isManagement(incoming().project_id) && isValidPayment(incoming());
      allow update: if isManagement(existing().project_id) && isValidPayment(incoming());
      allow delete: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      function isValidReport(data) {
        return data.project_id is string && data.employee_id == request.auth.uid &&
               data.type in ['DAILY', 'WEEKLY', 'MONTHLY'] &&
               data.progress_percent is number && data.progress_percent >= 0 && data.progress_percent <= 100;
      }
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReport(incoming());
      allow update: if isSignedIn() && existing().employee_id == request.auth.uid && isValidReport(incoming());
      allow delete: if isAdmin() || (isSignedIn() && existing().employee_id == request.auth.uid);
    }
  }
}
